# Keep line endings correct across platforms. Shell scripts must stay LF or they
# fail to run on macOS and Linux; Windows batch files want CRLF.
* text=auto
*.sh   text eol=lf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Rendered media is binary: no line-ending conversion, no diff noise.
*.png binary
*.gif binary
